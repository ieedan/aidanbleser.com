{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
      "build": {
        "dependsOn": ["^build"],
        "inputs": ["$TURBO_DEFAULT", ".env*"],
        "outputs": [".svelte-kit/**", ".vercel/**"]
      },
      "format": {},
      "lint": {
        "dependsOn": ["format"]
      },
      "dev": {
        "cache": false,
        "persistent": true
      }
    }
  }