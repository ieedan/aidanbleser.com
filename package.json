{
	"name": "aidanbleser.com",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@10.28.2",
	"scripts": {
		"dev": "dotenvx run -f .env.local -- pnpm dev:vite",
		"dev:vite": "vite dev --host",
		"build": "vite build",
		"build:dev": "dotenvx run -f .env.local -- pnpm build",
		"content:build": "tsx scripts/build-content.ts",
		"prepare": "svelte-kit sync || echo '' && pnpm content:build",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@dotenvx/dotenvx": "^1.52.0",
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.2",
		"@ethercorps/sveltekit-og": "^4.2.1",
		"@lukulent/svelte-umami": "^0.0.4",
		"@shikijs/langs": "^3.22.0",
		"@shikijs/markdown-it": "^3.22.0",
		"@shikijs/themes": "^3.22.0",
		"@shikijs/transformers": "^3.22.0",
		"@sveltejs/adapter-vercel": "^6.3.1",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@t3-oss/env-core": "^0.13.10",
		"@tailwindcss/vite": "^4.1.18",
		"@types/markdown-it": "^14.1.2",
		"@types/node": "^22.19.8",
		"bits-ui": "^2.15.5",
		"clsx": "^2.1.1",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.3.0",
		"jsrepo": "^3.2.1",
		"markdown-it": "^14.1.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"remixicon-svelte": "^0.0.5",
		"shiki": "^3.22.0",
		"svelte": "^5.49.1",
		"svelte-check": "^4.3.6",
		"svelte-meta-tags": "^4.5.0",
		"tailwind-merge": "^3.4.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.18",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite": "^7.3.1",
		"vite-plugin-transform-remixicon-imports": "^0.0.3",
		"zod": "^4.3.6"
	}
}
